# array_type_value_large.code
# Tests a value-typed fixed array with 5 elements (powers of 2).
# Verifies that the IR stores [i32 1, i32 2, i32 4, i32 8, i32 16].

type Lut {
    const data: int[5; 1, 2, 4, 8, 16] = [1, 2, 4, 8, 16]
    id: int

    static fn new(i: int): Lut {
        return Self { id: i };
    }

    fn getId(): int {
        return self.id;
    }
}

fn main() {
    let l = Lut.new(42);
    print(l.getId());
}
