import "stdlib/stream";

# stream_io.code — exercises MemoryStream as a print-capture buffer,
# file I/O via toFile / fromFile / appendToFile, and Stdout.writeByte.
#
# Expected output (7 lines):
#   captured
#   hello from file
#   hello from file
#   appended
#   true
#   65
#   66

fn main(): void {

    # ── MemoryStream as a print sink  ─────────────────────────────────────────
    # writeln() on a MemoryStream is the stream-based equivalent of print():
    # output goes to the buffer instead of stdout, enabling capture / redirect.
    const buf: MemoryStream = MemoryStream.new();
    buf.writeln("captured");
    print(buf.readLine());   # captured
    buf.free();

    # ── MemoryStream.toFile / fromFile  ───────────────────────────────────────
    const path: string = "/tmp/codelang_stream_io_test.txt";

    const w: MemoryStream = MemoryStream.new();
    w.writeln("hello from file");
    w.toFile(path);
    w.free();

    # Read back via fromFile
    const r: MemoryStream = MemoryStream.fromFile(path);
    print(r.readLine());   # hello from file
    r.free();

    # Read the same path a second time to confirm persistence
    const r2: MemoryStream = MemoryStream.fromFile(path);
    print(r2.readLine());   # hello from file
    r2.free();

    # ── MemoryStream.appendToFile  ────────────────────────────────────────────
    const a: MemoryStream = MemoryStream.from("appended\n");
    a.appendToFile(path);
    a.free();

    const full: MemoryStream = MemoryStream.fromFile(path);
    full.readLine();              # skip "hello from file"
    print(full.readLine());       # appended
    full.free();

    # ── toFile returns bool  ──────────────────────────────────────────────────
    const t: MemoryStream = MemoryStream.from("ok\n");
    const ok: bool = t.toFile(path);
    print(ok.toString());   # true
    t.free();

    # ── Stdout ByteWritable (writeByte) verification  ─────────────────────────
    # Verify writeByte works by capturing bytes in a MemoryStream then reading
    # back their numeric values — keeps stdout clean for line-based testing.
    const probe: MemoryStream = MemoryStream.new();
    probe.writeByte(65);    # 'A'
    probe.writeByte(66);    # 'B'
    print(probe.readByte().toString());   # 65
    print(probe.readByte().toString());   # 66
    probe.free();
}
