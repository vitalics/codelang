import "../../../stdlib/string";

# ── break / continue — comprehensive fixture ────────────────────────────────
#
# Expected output (18 lines total):
#   while_break
#   4
#   while_continue
#   1
#   3
#   5
#   for_break
#   6
#   3
#   for_continue
#   1
#   3
#   5
#   nested_inner
#   2
#   nested_outer
#   3
#   done

fn main() {
    # ── break in while loop ──────────────────────────────────────────────────
    # j iterates 1,2,3,4,...; we sum j while j < 4, break when j == 4.
    # After loop: j == 4.
    print("while_break");
    let j: int = 1;
    while j <= 10 {
        if j == 4 {
            break;
        }
        j = j + 1;
    }
    print(j);               # 4

    # ── continue in while loop — only print odd numbers 1..5 ─────────────────
    print("while_continue");
    let k: int = 0;
    while k < 6 {
        k = k + 1;
        if k == 2 || k == 4 || k == 6 {
            continue;
        }
        print(k);           # 1, 3, 5
    }

    # ── break in for loop: sum 1..3, break at 4 ──────────────────────────────
    print("for_break");
    let fb: int = 0;
    for (let fi: int = 1; fi <= 10; fi++) {
        if fi == 4 {
            break;
        }
        fb = fb + fi;
    }
    print(fb);              # 1+2+3 = 6

    # for break: count iterations until n == 3
    let count: int = 0;
    for (let n: int = 0; n < 100; n++) {
        if n == 3 {
            break;
        }
        count = count + 1;
    }
    print(count);           # 3  (n = 0, 1, 2 → 3 increments)

    # ── continue in for loop — only print odd numbers 1..5 ───────────────────
    print("for_continue");
    for (let m: int = 1; m <= 5; m++) {
        if m == 2 || m == 4 {
            continue;
        }
        print(m);           # 1, 3, 5
    }

    # ── nested loops: break exits only the innermost loop ────────────────────
    # Inner loop should stop at inner == 2 every outer iteration.
    # Outer loop runs 3 full times (0, 1, 2).
    let last_inner: int = 0;
    let outer: int = 0;
    while outer < 3 {
        let inner: int = 0;
        while inner < 10 {
            if inner == 2 {
                break;          # exits inner only
            }
            inner = inner + 1;
        }
        last_inner = inner;     # always 2 when break fires
        outer = outer + 1;
    }
    print("nested_inner");
    print(last_inner);      # 2
    print("nested_outer");
    print(outer);           # 3

    print("done");
}
