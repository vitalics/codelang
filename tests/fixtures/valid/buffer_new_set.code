# buffer_new_set.code
# Tests buffer_new() (zero-filled allocation) and set() mutation.

import "../../../stdlib/string";

fn main() {
    let b: Buffer = buffer_new(3);

    print(b.length());   # 3
    print(b.get(0));     # 0  (zero-filled)
    print(b.get(1));     # 0
    print(b.get(2));     # 0

    b.set(0, 65);        # 'A'
    b.set(1, 66);        # 'B'
    b.set(2, 67);        # 'C'

    print(b.get(0));     # 65
    print(b.get(1));     # 66
    print(b.get(2));     # 67

    b.free();
}
