# tests/fixtures/valid/map_countable.code
#
# Exercises Countable (length()) for PtrMap types.
#
# Expected output (5 lines):
#   2    — IntPtrMap length()
#   2    — StringPtrMap length()
#   2    — PtrIntMap length()
#   2    — PtrStringMap length()
#   2    — PtrPtrMap length()

import "../../../stdlib/map";

type Tag { id: int }
type Doc { score: int }

fn main() {
    # IntPtrMap
    let t1: Tag = Tag { id: 1 };
    let t2: Tag = Tag { id: 2 };
    let m1: Map<int, Tag> = IntPtrMap.new();
    m1.put(1, t1);
    m1.put(2, t2);
    print(m1.length());     # 2

    # StringPtrMap
    let m2: Map<string, Tag> = StringPtrMap.new();
    m2.put("a", t1);
    m2.put("b", t2);
    print(m2.length());     # 2

    # PtrIntMap
    let m3: Map<Tag, int> = PtrIntMap.new();
    m3.put(t1, 10);
    m3.put(t2, 20);
    print(m3.length());     # 2

    # PtrStringMap
    let m4: Map<Tag, string> = PtrStringMap.new();
    m4.put(t1, "hello");
    m4.put(t2, "world");
    print(m4.length());     # 2

    # PtrPtrMap
    let d1: Doc = Doc { score: 99 };
    let d2: Doc = Doc { score: 42 };
    let m5: Map<Tag, Doc> = PtrPtrMap.new();
    m5.put(t1, d1);
    m5.put(t2, d2);
    print(m5.length());     # 2
}
