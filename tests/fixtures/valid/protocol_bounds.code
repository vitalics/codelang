# protocol_bounds.code
#
# Tests protocol bounds on type parameters:
#   `T extends Printable` — the `extends` constraint is parsed and stored but
#   dispatch still works through the concrete extension method table.
#
# When T is resolved to `int` (i32), `something.toFloat()` dispatches via the
# built-in int method table. When T is `string`, `something.toString()` uses
# the built-in string method.
#
# This fixture validates:
#   1. The grammar accepts `T extends ProtocolName` in type params
#   2. Extension declarations with bounded params still work
#   3. Existing method dispatch is unaffected

protocol Displayable {
    fn toString(): string;
}

fn identity<T>(const v: T): T {
    return v;
}

fn main() {
    let x: int = identity(42);
    let s: string = identity("hello");
    print(x);
    print(s);
}
