# c_interop_abs.code
#
# Runtime tests for abs() and labs().
#
# Expected output (5 lines):
#   7           ← abs(-7)
#   7           ← abs(7)     identity on positive
#   0           ← abs(0)     identity on zero
#   1000        ← labs(-1000)
#   2147483648  ← labs(2147483648)  value exceeds i32 max, fits in i64

import "../../../stdlib/c-interop";

fn main() {
    print(abs(-7));
    print(abs(7));
    print(abs(0));
    print(labs(-1000));
    print(labs(2147483648));
}
