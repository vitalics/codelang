# switch inside a for-loop, accumulating results
fn classify(n: int): string {
    return switch n {
        1 => "one",
        2 => "two",
        3 => "three",
        else => "many",
    };
}

fn main() {
    # switch used as a function return value directly
    print(classify(1));   # one
    print(classify(2));   # two
    print(classify(3));   # three
    print(classify(99));  # many

    # switch inside a loop — classify every element
    let i: int = 1;
    while i <= 4 {
        let s = switch i {
            1 => "one",
            2 => "two",
            3 => "three",
            else => "other",
        };
        print(s);
        i = i + 1;
    }
    # expected: one two three other

    # switch as the argument to print directly
    print(switch 7 {
        7 => "lucky",
        else => "unlucky",
    });  # lucky
}
