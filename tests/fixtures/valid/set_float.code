import "../../../stdlib/set";
import "../../../stdlib/numbers";

fn main() {
    # ── FloatSet (f32) ────────────────────────────────────────────────────────
    let fs: FloatSet = FloatSet.new();
    fs.add(3.0);
    fs.add(1.0);
    fs.add(2.0);
    fs.add(1.0);              # duplicate — ignored
    print(fs.size());         # 3
    print(fs.contains(1.0));  # true
    print(fs.contains(5.0));  # false
    print(fs);                # {1, 2, 3}
    fs.remove(2.0);
    print(fs);                # {1, 3}
    fs.free();

    # ── DoubleSet (f64) ───────────────────────────────────────────────────────
    let ds: DoubleSet = DoubleSet.new();
    ds.add(10.5);
    ds.add(20.5);
    ds.add(10.5);             # duplicate — ignored
    print(ds.size());         # 2
    print(ds.contains(20.5)); # true
    print(ds);                # {10.5, 20.5}
    ds.free();

    # ── Set<Float> generic alias → FloatSet ────────────────────────────────────
    let gf: Set<Float> = FloatSet.new();
    gf.add(9.0);
    gf.add(7.0);
    gf.add(8.0);
    print(gf.size());         # 3
    print(gf);                # {7, 8, 9}
    gf.free();
}
