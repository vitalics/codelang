{
  "compilerOptions": {
    "target":      "ES2022",
    "module":      "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir":      "./out",
    "rootDir":     "./src",
    "strict":      true,
    "declaration": false,
    "sourceMap":   true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "out"]
}
