{
    "comments": {
        "lineComment": "#",
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{",  "close": "}" },
        { "open": "[",  "close": "]" },
        { "open": "(",  "close": ")" },
        { "open": "\"", "close": "\"", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        ["{",  "}"],
        ["[",  "]"],
        ["(",  ")"],
        ["\"", "\""]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*#\\s*region\\b",
            "end":   "^\\s*#\\s*endregion\\b"
        }
    },
    "wordPattern": "[_a-zA-Z][\\w_]*"
}
