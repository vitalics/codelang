# PtrPtrMap — ordered map from pointer/struct keys (by identity) to pointer/struct values
# ════════════════════════════════════════════════════════════════════════════════

export type PtrPtrMap = intrinsic("%PtrPtrMap*");

# ── C runtime bindings ────────────────────────────────────────────────────────
# Both key and val are passed as string (i8*); the IR generator bitcasts the
# actual struct pointers to i8* before each call.

export extern fn ptrptrmap_new(): PtrPtrMap;
export extern fn ptrptrmap_free(const m: PtrPtrMap);
export extern fn ptrptrmap_size(const m: PtrPtrMap): int;
export extern fn ptrptrmap_contains(const m: PtrPtrMap, const key: string): int;
export extern fn ptrptrmap_put(m: PtrPtrMap, const key: string, val: string);  # both stored as void*
