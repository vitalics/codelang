export extern fn ptrptrmap_print(const m: PtrPtrMap);
export extern fn ptrptrmap_to_string(const m: PtrPtrMap): string;

# ── Core extension methods ────────────────────────────────────────────────────
# Note: get/put are omitted — the IR generator emits those calls directly with
#       type-aware bitcasts since there is no single CodeLang type for void*.

PtrPtrMap extends {

    # new(): static factory — creates an empty PtrPtrMap.
    export static fn new(): PtrPtrMap {
        return ptrptrmap_new();
    }

    # size(): number of key-value pairs.
    export fn size(): int {
        return ptrptrmap_size(self);
    }

    # contains(key): true if key is present in this map.
    export fn contains(const key: string): bool {
        let r = ptrptrmap_contains(self, key);
        if r == 1 {
            return true;
        }
        return false;
    }

    # remove(key): delete key.  No-op if key is absent.
    export fn remove(const key: string) {
        ptrptrmap_remove(self, key);
    }

    # free(): release the heap memory owned by this PtrPtrMap.
    export fn free() {
        ptrptrmap_free(self);
    }
}

PtrPtrMap extends Countable {
    export fn length(): int {
        return ptrptrmap_size(self);
    }
}

PtrPtrMap extends Displayable {
    export fn toString(): string {
        return ptrptrmap_to_string(self);
    }
}

PtrPtrMap extends Disposable {
    export fn dispose() {
        ptrptrmap_free(self);
    }
}

# ══════════════════════════════════════════════════════════════════════
# Generic Map<K, V> alias — compile-time resolution:
#   Map<int, int>       → IntIntMap
#   Map<int, string>    → IntStringMap
#   Map<string, int>    → StringIntMap
#   Map<string, string> → StringStringMap
#   Map<int, T>         → IntPtrMap      (T = user-defined struct)
#   Map<string, T>      → StringPtrMap   (T = user-defined struct)
#   Map<T, int>         → PtrIntMap      (T = user-defined struct, key by identity)
#   Map<T, string>      → PtrStringMap   (T = user-defined struct, key by identity)
#   Map<T, V>           → PtrPtrMap      (both = user-defined structs, key by identity)
# ══════════════════════════════════════════════════════════════════════

export type Map<K, V> = intrinsic("%Map");

# ════════════════════════════════════════════════════════════════════════════════
# Backward-compatible getSafe aliases.
#
# getSafe(key) is now an alias for get(key) — both return Option<V>.
# Prefer get(key) in new code.
# ════════════════════════════════════════════════════════════════════════════════

IntIntMap extends {
    export fn getSafe(const key: int): Option<int> { return self.get(key); }
}

IntStringMap extends {
    export fn getSafe(const key: int): Option<string> { return self.get(key); }
}

StringIntMap extends {
    export fn getSafe(const key: string): Option<int> { return self.get(key); }
}

StringStringMap extends {
    export fn getSafe(const key: string): Option<string> { return self.get(key); }
}

# Note: PtrIntMap.getSafe() and PtrStringMap.getSafe() are defined inline
# in the PtrIntMap and PtrStringMap extension blocks above.
