# ════════════════════════════════════════════════════════════════════════════════
# IntPtrMap — ordered map from int keys to pointer/struct values
# ════════════════════════════════════════════════════════════════════════════════

export type IntPtrMap = intrinsic("%IntPtrMap*");

# ── C runtime bindings ────────────────────────────────────────────────────────

export extern fn intptrmap_new(): IntPtrMap;
export extern fn intptrmap_free(const m: IntPtrMap);
export extern fn intptrmap_size(const m: IntPtrMap): int;
export extern fn intptrmap_contains(const m: IntPtrMap, const key: int): int;
export extern fn intptrmap_put(m: IntPtrMap, const key: int, val: string);  # val stored as void*
export extern fn intptrmap_remove(m: IntPtrMap, const key: int);
export extern fn intptrmap_print(const m: IntPtrMap);
export extern fn intptrmap_to_string(const m: IntPtrMap): string;

# ── Core extension methods ────────────────────────────────────────────────────
# Note: get/put are omitted — the IR generator emits those calls directly with
#       type-aware bitcasts since there is no single CodeLang type for void*.

IntPtrMap extends {

    # new(): static factory — creates an empty IntPtrMap.
    export static fn new(): IntPtrMap {
        return intptrmap_new();
    }

    # size(): number of key-value pairs.
    export fn size(): int {
        return intptrmap_size(self);
    }

    # contains(key): true if key is present in this map.
    export fn contains(const key: int): bool {
        let r = intptrmap_contains(self, key);
        if r == 1 {
            return true;
        }
        return false;
    }

    # remove(key): delete key.  No-op if key is absent.
    export fn remove(const key: int) {
        intptrmap_remove(self, key);
    }

    # free(): release the heap memory owned by this IntPtrMap.
    export fn free() {
        intptrmap_free(self);
    }
}

IntPtrMap extends Countable {
    export fn length(): int {
        return intptrmap_size(self);
    }
}

IntPtrMap extends Displayable {
    export fn toString(): string {
        return intptrmap_to_string(self);
    }
}

IntPtrMap extends Disposable {
    export fn dispose() {
        intptrmap_free(self);
    }
}

