# stdlib/map.code
#
# IntIntMap       — heap-allocated ordered map from int keys to int values.
# IntStringMap    — heap-allocated ordered map from int keys to string values.
# StringIntMap    — heap-allocated ordered map from string keys to int values.
# StringStringMap — heap-allocated ordered map from string keys to string values.
#
# All four types are backed by sorted dynamic arrays for predictable
# iteration order and O(log n) key lookups.
#
# ── Quick reference ───────────────────────────────────────────────────────────
#
#   let m: IntIntMap = IntIntMap.new();   # empty map
#
#   m.put(1, 42)                          # insert or update a key-value pair
#   m.get(1)                              # 42  (0 if key absent)
#   m.contains(1)                         # true / false
#   m.remove(1)                           # remove key (no-op if absent)
#   m.size()                              # number of key-value pairs
#
#   print(m)                              # {1: 42}
#   m.toString()                          # "{1: 42}"
#
#   m.free()                              # release heap memory
#   using m: IntIntMap = IntIntMap.new(); # auto-dispose on scope exit
#
# Generic alias:
#   let m: Map<int, int>       = IntIntMap.new();
#   let m: Map<int, string>    = IntStringMap.new();
#   let m: Map<string, int>    = StringIntMap.new();
#   let m: Map<string, string> = StringStringMap.new();

import "./protocols";
import "./boolean";
import "./option";

# ════════════════════════════════════════════════════════════════════════════════
# IntIntMap — ordered map from int keys to int values
# ════════════════════════════════════════════════════════════════════════════════

export type IntIntMap = intrinsic("%IntIntMap*");

# ── C runtime bindings ────────────────────────────────────────────────────────

export extern fn intintmap_new(): IntIntMap;
export extern fn intintmap_free(const m: IntIntMap);
export extern fn intintmap_size(const m: IntIntMap): int;
export extern fn intintmap_contains(const m: IntIntMap, const key: int): int;
export extern fn intintmap_get(const m: IntIntMap, const key: int): int;
export extern fn intintmap_put(m: IntIntMap, const key: int, const val: int);
export extern fn intintmap_remove(m: IntIntMap, const key: int);
export extern fn intintmap_print(const m: IntIntMap);
export extern fn intintmap_to_string(const m: IntIntMap): string;

# ── Core extension methods ────────────────────────────────────────────────────

IntIntMap extends {

    # new(): static factory — creates an empty IntIntMap.
    export static fn new(): IntIntMap {
        return intintmap_new();
    }

    # size(): number of key-value pairs.
    export fn size(): int {
        return intintmap_size(self);
    }

    # contains(key): true if key is present in this map.
    export fn contains(const key: int): bool {
        let r = intintmap_contains(self, key);
        if r == 1 {
            return true;
        }
        return false;
    }

    # get(key): Some(value) if key is present, None if absent.
    export fn get(const key: int): Option<int> {
        let r: int = intintmap_contains(self, key);
        if r == 1 {
            return Option::Some(intintmap_get(self, key));
        }
        return Option::None;
    }

    # getOr(key, default): value for key, or default if absent.
    export fn getOr(const key: int, const default: int): int {
        let r: int = intintmap_contains(self, key);
        if r == 1 {
            return intintmap_get(self, key);
        }
        return default;
    }

    # put(key, val): insert or update the key-value pair.
    export fn put(const key: int, const val: int) {
        intintmap_put(self, key, val);
    }

    # remove(key): delete key.  No-op if key is absent.
    export fn remove(const key: int) {
        intintmap_remove(self, key);
    }

    # free(): release the heap memory owned by this IntIntMap.
    export fn free() {
        intintmap_free(self);
    }
}

IntIntMap extends Countable {
    export fn length(): int {
        return intintmap_size(self);
    }
}

IntIntMap extends Displayable {
    export fn toString(): string {
        return intintmap_to_string(self);
    }
}

IntIntMap extends Disposable {
    export fn dispose() {
        intintmap_free(self);
    }
}

