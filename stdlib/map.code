# ════════════════════════════════════════════════════════════════════════════════
# PtrIntMap — ordered map from pointer/struct keys (by identity) to int values
# ════════════════════════════════════════════════════════════════════════════════

export type PtrIntMap = intrinsic("%PtrIntMap*");

# ── C runtime bindings ────────────────────────────────────────────────────────
# key is passed as string (i8*); the IR generator bitcasts the actual struct
# pointer to i8* before each call.

export extern fn ptrintmap_new(): PtrIntMap;
export extern fn ptrintmap_free(const m: PtrIntMap);
export extern fn ptrintmap_size(const m: PtrIntMap): int;
export extern fn ptrintmap_contains(const m: PtrIntMap, const key: string): int;
export extern fn ptrintmap_get(const m: PtrIntMap, const key: string): int;
export extern fn ptrintmap_put(m: PtrIntMap, const key: string, const val: int);
export extern fn ptrintmap_remove(m: PtrIntMap, const key: string);
export extern fn ptrintmap_print(const m: PtrIntMap);
export extern fn ptrintmap_to_string(const m: PtrIntMap): string;

# ── Core extension methods ────────────────────────────────────────────────────
# Note: get/put/contains/remove key parameters are string (i8*) in CodeLang;
#       the IR generator bitcasts the actual struct pointer before the call.

PtrIntMap extends {

    # new(): static factory — creates an empty PtrIntMap.
    export static fn new(): PtrIntMap {
        return ptrintmap_new();
    }

    # size(): number of key-value pairs.
    export fn size(): int {
        return ptrintmap_size(self);
    }

    # contains(key): true if key is present in this map.
    export fn contains(const key: string): bool {
        let r = ptrintmap_contains(self, key);
        if r == 1 {
            return true;
        }
        return false;
    }

    # get(key): return the value for key, or 0 if absent.
    export fn get(const key: string): int {
        return ptrintmap_get(self, key);
    }

    # getSafe(key): Some(value) if key is present, None if absent.
    export fn getSafe(const key: string): Option<int> {
        let r: int = ptrintmap_contains(self, key);
        if r == 1 {
            return Option::Some(ptrintmap_get(self, key));
        }
        return Option::None;
    }

    # getOr(key, default): return the value for key, or default if absent.
    export fn getOr(const key: string, const default: int): int {
        let r: int = ptrintmap_contains(self, key);
        if r == 1 {
            return ptrintmap_get(self, key);
        }
        return default;
    }

    # put(key, val): insert or update the key-value pair.
    export fn put(const key: string, const val: int) {
        ptrintmap_put(self, key, val);
    }

    # remove(key): delete key.  No-op if key is absent.
    export fn remove(const key: string) {
        ptrintmap_remove(self, key);
    }

    # free(): release the heap memory owned by this PtrIntMap.
    export fn free() {
        ptrintmap_free(self);
    }
}

PtrIntMap extends Countable {
    export fn length(): int {
        return ptrintmap_size(self);
    }
}

PtrIntMap extends Displayable {
    export fn toString(): string {
        return ptrintmap_to_string(self);
    }
}

PtrIntMap extends Disposable {
    export fn dispose() {
        ptrintmap_free(self);
    }
}

