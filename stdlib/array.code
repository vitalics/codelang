# ════════════════════════════════════════════════════════════════════════════════
# Backward-compat aliases
#
# The primary safe API is now at/first/last/pop/shift (all return Option<T>).
# The xSafe() names are kept so existing code continues to compile.
# ════════════════════════════════════════════════════════════════════════════════

# ── IntArray aliases ──────────────────────────────────────────────────────────

IntArray extends {
    # getSafe(i): strict bounds check — None for any index < 0 or >= length.
    # Does NOT support negative-index wrapping (use at(i) for that).
    export fn getSafe(const i: int): Option<int> {
        if i >= 0 && i < intarray_length(self) {
            return Option::Some(intarray_get(self, i));
        }
        return Option::None;
    }
    # popSafe(): alias for pop(). Prefer pop() in new code.
    export fn popSafe(): Option<int> {
        return self.pop();
    }
    # shiftSafe(): alias for shift(). Prefer shift() in new code.
    export fn shiftSafe(): Option<int> {
        return self.shift();
    }
    # firstSafe(): alias for first(). Prefer first() in new code.
    export fn firstSafe(): Option<int> {
        return self.first();
    }
    # lastSafe(): alias for last(). Prefer last() in new code.
    export fn lastSafe(): Option<int> {
        return self.last();
    }
}

# ── StringArray aliases ───────────────────────────────────────────────────────

StringArray extends {
    # getSafe(i): strict bounds check — None for any index < 0 or >= length.
    # Does NOT support negative-index wrapping (use at(i) for that).
    export fn getSafe(const i: int): Option<string> {
        if i >= 0 && i < stringarray_length(self) {
            return Option::Some(stringarray_get(self, i));
        }
        return Option::None;
    }
    # popSafe(): alias for pop(). Prefer pop() in new code.
    export fn popSafe(): Option<string> {
        return self.pop();
    }
    # shiftSafe(): alias for shift(). Prefer shift() in new code.
    export fn shiftSafe(): Option<string> {
        return self.shift();
    }
    # firstSafe(): alias for first(). Prefer first() in new code.
    export fn firstSafe(): Option<string> {
        return self.first();
    }
    # lastSafe(): alias for last(). Prefer last() in new code.
    export fn lastSafe(): Option<string> {
        return self.last();
    }
}

# ── BoolArray aliases ─────────────────────────────────────────────────────────

BoolArray extends {
    # getSafe(i): strict bounds check — None for any index < 0 or >= length.
    export fn getSafe(const i: int): Option<bool> {
        if i >= 0 && i < boolarray_length(self) {
            let raw: int = boolarray_get(self, i);
            if raw == 1 {
                return Option::Some(true);
            }
            return Option::Some(false);
        }
        return Option::None;
    }
}

# ════════════════════════════════════════════════════════════════════════════════
# Higher-Order Functions for IntArray
#
# Inspired by JavaScript's Array prototype and Rust's Iterator trait.
# All HOF accept a function value (named fn or inline lambda) as their
# first argument; they never mutate self unless noted.
#
# Quick reference:
#
#   a.forEach(fn(x: int): void { print(x); })    # side-effects over each element
#   a.map(double)                                  # new IntArray: f applied to each
#   a.filter(isEven)                               # new IntArray: keep matching
#   a.every(isPositive)                            # true if ALL satisfy predicate
#   a.some(isEven)                                 # true if ANY satisfies predicate
#   a.reduce(sum, 0)                               # fold left: acc = f(acc, elem)
#   a.find(isEven)                                 # Option<int>: first match
#   a.findIndex(isEven)                            # int: index of first match, or -1
# ════════════════════════════════════════════════════════════════════════════════

IntArray extends {

    # forEach(f): call f(element) for each element in order.
    # Side-effects only — does not produce a new array.
    # JS: arr.forEach(x => ...) / Rust: iter.for_each(|x| ...)
    export fn forEach(const f: fn(int): void) {
        let i: int = 0;
        let len: int = intarray_length(self);
        while i < len {
            f(intarray_get(self, i));
            i = i + 1;
        }
    }

    # map(f): new IntArray where each element is f(old_element).
    # Caller is responsible for freeing the returned array.
    # JS: arr.map(x => x * 2) / Rust: iter.map(|x| x * 2).collect()
    export fn map(const f: fn(int): int): IntArray {
        let len: int = intarray_length(self);
        let result: IntArray = intarray_new_with_capacity(len);
        let i: int = 0;
        while i < len {
            intarray_push(result, f(intarray_get(self, i)));
            i = i + 1;
        }
        return result;
    }

    # filter(f): new IntArray with only elements for which f(element) == true.
    # Caller is responsible for freeing the returned array.
    # JS: arr.filter(x => x > 0) / Rust: iter.filter(|&x| x > 0).collect()
    export fn filter(const f: fn(int): bool): IntArray {
        let len: int = intarray_length(self);
        let result: IntArray = intarray_new();
        let i: int = 0;
        while i < len {
            let v: int = intarray_get(self, i);
            if f(v) {
                intarray_push(result, v);
            }
            i = i + 1;
        }
        return result;
    }

    # every(f): true if f(element) returns true for ALL elements.
    # Returns true for an empty array (vacuous truth).
    # JS: arr.every(x => x > 0) / Rust: iter.all(|&x| x > 0)
    export fn every(const f: fn(int): bool): bool {
        let len: int = intarray_length(self);
        let i: int = 0;
        while i < len {
            if !f(intarray_get(self, i)) {
                return false;
            }
            i = i + 1;
        }
        return true;
    }

    # some(f): true if f(element) returns true for AT LEAST ONE element.
    # Returns false for an empty array.
    # JS: arr.some(x => x > 0) / Rust: iter.any(|&x| x > 0)
    export fn some(const f: fn(int): bool): bool {
        let len: int = intarray_length(self);
        let i: int = 0;
        while i < len {
            if f(intarray_get(self, i)) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    # reduce(f, init): left fold — acc = f(acc, element) starting from init.
    # JS: arr.reduce((acc, x) => acc + x, 0) / Rust: iter.fold(0, |acc, x| acc + x)
    export fn reduce(const f: fn(int, int): int, const init: int): int {
        let len: int = intarray_length(self);
        let acc: int = init;
        let i: int = 0;
        while i < len {
            acc = f(acc, intarray_get(self, i));
            i = i + 1;
        }
        return acc;
    }

    # find(f): first element for which f(element) == true, wrapped in Some; None if none match.
    # JS: arr.find(x => x > 3) / Rust: iter.find(|&&x| x > 3)
    export fn find(const f: fn(int): bool): Option<int> {
        let len: int = intarray_length(self);
        let i: int = 0;
        while i < len {
            let v: int = intarray_get(self, i);
            if f(v) {
                return Option::Some(v);
            }
            i = i + 1;
        }
        return Option::None;
    }

    # findIndex(f): index of first element where f(element) == true, or -1.
    # JS: arr.findIndex(x => x > 3) / Rust: iter.position(|&x| x > 3)
    export fn findIndex(const f: fn(int): bool): int {
        let len: int = intarray_length(self);
        let i: int = 0;
        while i < len {
            if f(intarray_get(self, i)) {
                return i;
            }
            i = i + 1;
        }
        return -1;
    }

}

# ════════════════════════════════════════════════════════════════════════════════
# Higher-Order Functions for StringArray
# ════════════════════════════════════════════════════════════════════════════════

StringArray extends {

    # forEach(f): call f(element) for each element in order.
    export fn forEach(const f: fn(string): void) {
        let i: int = 0;
        let len: int = stringarray_length(self);
        while i < len {
            f(stringarray_get(self, i));
            i = i + 1;
        }
    }

    # map(f): new StringArray where each element is f(old_element).
    export fn map(const f: fn(string): string): StringArray {
        let len: int = stringarray_length(self);
        let result: StringArray = stringarray_new_with_capacity(len);
        let i: int = 0;
        while i < len {
            stringarray_push(result, f(stringarray_get(self, i)));
            i = i + 1;
        }
        return result;
    }

    # filter(f): new StringArray with only elements for which f returns true.
    export fn filter(const f: fn(string): bool): StringArray {
        let len: int = stringarray_length(self);
        let result: StringArray = stringarray_new();
        let i: int = 0;
        while i < len {
            let v: string = stringarray_get(self, i);
            if f(v) {
                stringarray_push(result, v);
            }
            i = i + 1;
        }
        return result;
    }

    # every(f): true if f(element) == true for ALL elements.
    export fn every(const f: fn(string): bool): bool {
        let len: int = stringarray_length(self);
        let i: int = 0;
        while i < len {
            if !f(stringarray_get(self, i)) {
                return false;
            }
            i = i + 1;
        }
        return true;
    }

    # some(f): true if f(element) == true for AT LEAST ONE element.
    export fn some(const f: fn(string): bool): bool {
        let len: int = stringarray_length(self);
        let i: int = 0;
        while i < len {
            if f(stringarray_get(self, i)) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    # find(f): first element for which f returns true, wrapped in Some; None if none match.
    export fn find(const f: fn(string): bool): Option<string> {
        let len: int = stringarray_length(self);
        let i: int = 0;
        while i < len {
            let v: string = stringarray_get(self, i);
            if f(v) {
                return Option::Some(v);
            }
            i = i + 1;
        }
        return Option::None;
    }

    # findIndex(f): index of first element where f returns true, or -1.
    export fn findIndex(const f: fn(string): bool): int {
        let len: int = stringarray_length(self);
        let i: int = 0;
        while i < len {
            if f(stringarray_get(self, i)) {
                return i;
            }
            i = i + 1;
        }
        return -1;
    }

}
