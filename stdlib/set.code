# stdlib/set.code
#
# IntSet    — heap-allocated, ordered set of 32-bit integers.
# StringSet — heap-allocated, ordered set of string pointers.
# BoolSet   — heap-allocated set of boolean values (at most {false, true}).
#
# All three types are backed by sorted dynamic arrays for predictable
# iteration order and O(log n) membership tests.
#
# ── Quick reference ───────────────────────────────────────────────────────────
#
#   let s: IntSet = IntSet.new();     # empty set
#
#   s.add(3)                          # add element (no-op if already present)
#   s.remove(3)                       # remove element (no-op if absent)
#   s.contains(3)                     # true / false
#   s.size()                          # number of distinct elements
#
#   print(s)                          # {1, 2, 3}
#   s.toString()                      # "{1, 2, 3}"
#
#   s.free()                          # release heap memory
#   using s: IntSet = IntSet.new();   # auto-dispose on scope exit
#
# Generic alias:
#   let s: Set<int>    = IntSet.new();
#   let s: Set<string> = StringSet.new();
#   let s: Set<bool>   = BoolSet.new();

import "./protocols";
import "./boolean";
import "./option";

# ════════════════════════════════════════════════════════════════════════════════
# IntSet — ordered set of 32-bit integers
# ════════════════════════════════════════════════════════════════════════════════

export type IntSet = intrinsic("%IntSet*");

# ── C runtime bindings ────────────────────────────────────────────────────────

export extern fn intset_new(): IntSet;
export extern fn intset_free(const s: IntSet);
export extern fn intset_size(const s: IntSet): int;
export extern fn intset_contains(const s: IntSet, const v: int): int;
export extern fn intset_add(s: IntSet, const v: int);
export extern fn intset_remove(s: IntSet, const v: int);
export extern fn intset_print(const s: IntSet);
export extern fn intset_to_string(const s: IntSet): string;
export extern fn intset_at(const s: IntSet, const index: int): int;

# ── Core extension methods ────────────────────────────────────────────────────

IntSet extends {

    # new(): static factory — creates an empty IntSet.
    export static fn new(): IntSet {
        return intset_new();
    }

    # size(): number of distinct elements.
    export fn size(): int {
        return intset_size(self);
    }

    # contains(v): true if v is a member of this set.
    export fn contains(const v: int): bool {
        let r = intset_contains(self, v);
        if r == 1 {
            return true;
        }
        return false;
    }

    # add(v): insert v.  No-op if v is already present.
    export fn add(const v: int) {
        intset_add(self, v);
    }

    # remove(v): delete v.  No-op if v is absent.
    export fn remove(const v: int) {
        intset_remove(self, v);
    }

    # at(index): Some(element) at sorted position `index`, or None if out of bounds.
    # Negative indices count from the end: at(-1) → last element.
    export fn at(const index: int): Option<int> {
        let len: int = intset_size(self);
        let i: int = index;
        if index < 0 {
            i = len + index;
        }
        if i >= 0 && i < len {
            return Option::Some(intset_at(self, i));
        }
        return Option::None;
    }

    # atSafe(index): backward-compatible alias for at(index).
    export fn atSafe(const index: int): Option<int> { return self.at(index); }

    # free(): release the heap memory owned by this IntSet.
    export fn free() {
        intset_free(self);
    }
}

IntSet extends Countable {
    export fn length(): int {
        return intset_size(self);
    }
}

IntSet extends Displayable {
    export fn toString(): string {
        return intset_to_string(self);
    }
}

IntSet extends Disposable {
    export fn dispose() {
        intset_free(self);
    }
}

# ════════════════════════════════════════════════════════════════════════════════
# StringSet — ordered set of string pointers (lexicographic order)
# ════════════════════════════════════════════════════════════════════════════════

export type StringSet = intrinsic("%StringSet*");

# ── C runtime bindings ────────────────────────────────────────────────────────

export extern fn stringset_new(): StringSet;
export extern fn stringset_free(const s: StringSet);
export extern fn stringset_size(const s: StringSet): int;
export extern fn stringset_contains(const s: StringSet, const v: string): int;
export extern fn stringset_add(s: StringSet, const v: string);
export extern fn stringset_remove(s: StringSet, const v: string);
export extern fn stringset_print(const s: StringSet);
export extern fn stringset_to_string(const s: StringSet): string;
export extern fn stringset_at(const s: StringSet, const index: int): string;

# ── Core extension methods ────────────────────────────────────────────────────

StringSet extends {

    export static fn new(): StringSet {
        return stringset_new();
    }

    export fn size(): int {
        return stringset_size(self);
    }

    export fn contains(const v: string): bool {
        let r = stringset_contains(self, v);
        if r == 1 {
            return true;
        }
        return false;
    }

    export fn add(const v: string) {
        stringset_add(self, v);
    }

    export fn remove(const v: string) {
        stringset_remove(self, v);
    }

    # free(): release the heap memory owned by this StringSet.
    export fn free() {
        stringset_free(self);
    }
}

StringSet extends Countable {
    export fn length(): int {
        return stringset_size(self);
    }
}

StringSet extends Indexable {
    export fn at(const index: int): Option<string> {
        let len: int = stringset_size(self);
        let i: int = index;
        if index < 0 {
            i = len + index;
        }
        if i >= 0 && i < len {
            return Option::Some(stringset_at(self, i));
        }
        return Option::None;
    }
}

StringSet extends {
    # atSafe(index): backward-compatible alias for at(index).
    export fn atSafe(const index: int): Option<string> { return self.at(index); }
}

StringSet extends Displayable {
    export fn toString(): string {
        return stringset_to_string(self);
    }
}

StringSet extends Disposable {
    export fn dispose() {
        stringset_free(self);
    }
}

# ════════════════════════════════════════════════════════════════════════════════
# BoolSet — set of boolean values  (at most two members: false and/or true)
# ════════════════════════════════════════════════════════════════════════════════

