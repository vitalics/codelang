    }
}

# ════════════════════════════════════════════════════════════════════════════════
# Generic Set<T> alias
#
# Set<T> is a compile-time alias that resolves to the concrete set type for T:
#   Set<int>    → IntSet    (%IntSet*)
#   Set<string> → StringSet (%StringSet*)
#   Set<bool>   → BoolSet   (%BoolSet*)
#   Set<Float>  → FloatSet  (%FloatSet*)
#   Set<float>  → DoubleSet (%DoubleSet*)
#   Set<Number> → NumberSet (%NumberSet*)
#
# The %Set sentinel is never materialised in LLVM IR; the IR generator
# resolves the concrete type from the type argument.
# ════════════════════════════════════════════════════════════════════════════════

export type Set<T> = intrinsic("%Set");

# ════════════════════════════════════════════════════════════════════════════════
# Safe (Option-returning) accessors for all set types.
#
#   let v: Option<int> = s.atSafe(0);
#   switch v {
#       Option::Some(x) => print(x),
#       Option::None    => print("out of bounds"),
#   }
# ════════════════════════════════════════════════════════════════════════════════

# ── BoolSet safe accessor (atSafe) ───────────────────────────────────────────
# BoolSet.at() still returns bool; atSafe provides the Option-based alternative.

BoolSet extends {
    # atSafe(i): Option<bool> — Some(element) or None if i is out of bounds.
    export fn atSafe(const i: int): Option<bool> {
        let len: int = boolset_size(self);
        let idx: int = i;
        if i < 0 {
            idx = len + i;
        }
        if idx >= 0 && idx < len {
            return Option::Some(boolset_at(self, idx));
        }
        return Option::None;
    }
}

# ════════════════════════════════════════════════════════════════════════════════
# Higher-Order Functions for IntSet
#
# Sets iterate elements in sorted order (ascending).
# HOF match JavaScript's Set/Array conventions and Rust's Iterator trait.
#
# Quick reference:
#
#   s.forEach(fn(x: int): void { print(x); })   # side-effects over each element
#   s.every(isPositive)                           # true if ALL satisfy predicate
#   s.some(isEven)                                # true if ANY satisfies predicate
#   s.filter(isEven)                              # new IntSet: keep matching
#   s.find(isEven)                                # Option<int>: first match
# ════════════════════════════════════════════════════════════════════════════════

IntSet extends {

    # forEach(f): call f(element) for each element in ascending order.
    export fn forEach(const f: fn(int): void) {
        let i: int = 0;
        let sz: int = intset_size(self);
        while i < sz {
            f(intset_at(self, i));
            i = i + 1;
        }
    }

    # every(f): true if f(element) returns true for ALL elements.
    export fn every(const f: fn(int): bool): bool {
        let i: int = 0;
        let sz: int = intset_size(self);
        while i < sz {
            if !f(intset_at(self, i)) {
                return false;
            }
            i = i + 1;
        }
        return true;
    }

    # some(f): true if f(element) returns true for AT LEAST ONE element.
    export fn some(const f: fn(int): bool): bool {
        let i: int = 0;
        let sz: int = intset_size(self);
        while i < sz {
            if f(intset_at(self, i)) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    # filter(f): new IntSet containing only elements for which f returns true.
    # Caller is responsible for freeing the returned set.
    export fn filter(const f: fn(int): bool): IntSet {
        let sz: int = intset_size(self);
        let result: IntSet = intset_new();
        let i: int = 0;
        while i < sz {
            let v: int = intset_at(self, i);
            if f(v) {
                intset_add(result, v);
            }
            i = i + 1;
        }
        return result;
    }

    # find(f): first element (ascending) for which f returns true, wrapped in Some.
    export fn find(const f: fn(int): bool): Option<int> {
        let sz: int = intset_size(self);
        let i: int = 0;
        while i < sz {
            let v: int = intset_at(self, i);
            if f(v) {
                return Option::Some(v);
            }
            i = i + 1;
        }
        return Option::None;
    }

}

# ════════════════════════════════════════════════════════════════════════════════
# Higher-Order Functions for StringSet
# ════════════════════════════════════════════════════════════════════════════════

StringSet extends {

    # forEach(f): call f(element) for each element in lexicographic order.
    export fn forEach(const f: fn(string): void) {
        let i: int = 0;
        let sz: int = stringset_size(self);
        while i < sz {
            f(stringset_at(self, i));
            i = i + 1;
        }
    }

    # every(f): true if f(element) returns true for ALL elements.
    export fn every(const f: fn(string): bool): bool {
        let i: int = 0;
        let sz: int = stringset_size(self);
        while i < sz {
            if !f(stringset_at(self, i)) {
                return false;
            }
            i = i + 1;
        }
        return true;
    }

    # some(f): true if f(element) returns true for AT LEAST ONE element.
    export fn some(const f: fn(string): bool): bool {
        let i: int = 0;
        let sz: int = stringset_size(self);
        while i < sz {
            if f(stringset_at(self, i)) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    # filter(f): new StringSet containing only elements for which f returns true.
    export fn filter(const f: fn(string): bool): StringSet {
        let sz: int = stringset_size(self);
        let result: StringSet = stringset_new();
        let i: int = 0;
        while i < sz {
            let v: string = stringset_at(self, i);
            if f(v) {
                stringset_add(result, v);
            }
            i = i + 1;
        }
        return result;
    }

    # find(f): first element for which f returns true, wrapped in Some.
    export fn find(const f: fn(string): bool): Option<string> {
        let sz: int = stringset_size(self);
        let i: int = 0;
        while i < sz {
            let v: string = stringset_at(self, i);
            if f(v) {
                return Option::Some(v);
            }
            i = i + 1;
        }
        return Option::None;
    }

}
