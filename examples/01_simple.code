protocol Lolable {
  fn lol(): void;
}

fn process<T extends Displayable, Lolable>(const item: T) {
    print($"display: {item.toString()}, length: {item.lol()}");
}


Number extends Lolable {
  fn lol(): void {
    return 1;
  }
}

fn qwe(a: Number) {
  print($"a: {a}");
}

fn main() {
    let i: int = 1;
    process(10);
    qwe(10);
    panic("Something happends!");
}
